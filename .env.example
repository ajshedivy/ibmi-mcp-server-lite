# IBM i / Db2 for i connection (consumed by ${VAR} interpolation in tools YAML)
# NOTE: DB2i_HOST must match a name in the Mapepire server certificate's SAN —
# mapepire-java verifies the TLS hostname even with ignore-unauthorized: true.
# See docs/running-on-ibmi.md#tls-hostname-verification
DB2i_HOST=your-ibmi-host.example.com
DB2i_USER=your-user
DB2i_PASS=your-password
DB2i_PORT=8076

# Accept self-signed certificates from the Mapepire server
DB2i_IGNORE_UNAUTHORIZED=true

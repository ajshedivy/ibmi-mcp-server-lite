# IBM i / Db2 for i connection (consumed by ${VAR} interpolation in tools YAML)
# NOTE: DB2i_HOST must match a name in the Mapepire server certificate's SAN —
# mapepire-java verifies the TLS hostname even with ignore-unauthorized: true.
# See docs/running-on-ibmi.md#tls-hostname-verification
DB2i_HOST=your-ibmi-host.example.com
DB2i_USER=your-user
DB2i_PASS=your-password
DB2i_PORT=8076

# Accept self-signed certificates from the Mapepire server
DB2i_IGNORE_UNAUTHORIZED=true

# Hot-reload tools YAML on file change (default: true). Set to false or use --no-reload to disable.
YAML_AUTO_RELOAD=true

# Mapepire JDBC connection options (optional)
# Format: semicolon-separated key=value pairs (matches DB2 JDBC URL syntax)
# - Keys with spaces are allowed (e.g., "date format")
# - The "libraries" value is comma-separated (the only array-valued option)
# - All other values are forwarded as strings to the JDBC driver
# - Overrides any jdbc-options set in YAML sources
# Example: DB2i_JDBC_OPTIONS='naming=system;date format=iso;libraries=MYLIB,DEVDATA'
# DB2i_JDBC_OPTIONS=

# Multi-file YAML merge (--tools directory or glob). Only literal "true" enables a flag.
# YAML_MERGE_ARRAYS=true
# YAML_ALLOW_DUPLICATE_TOOLS=false
# YAML_ALLOW_DUPLICATE_SOURCES=false
# YAML_VALIDATE_MERGED=true
